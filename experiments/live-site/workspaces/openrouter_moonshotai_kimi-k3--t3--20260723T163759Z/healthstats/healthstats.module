<?php

/**
 * @file
 * Provides a JSON endpoint with basic site health statistics.
 */

/**
 * Implements hook_permission().
 */
function healthstats_permission() {
  return array(
    'view healthstats' => array(
      'title' => t('View health stats'),
      'description' => t('View the site health statistics JSON endpoint.'),
    ),
  );
}

/**
 * Implements hook_menu().
 */
function healthstats_menu() {
  $items['api/healthstats'] = array(
    'title' => 'Health stats',
    'page callback' => 'healthstats_json',
    'access arguments' => array('view healthstats'),
    'delivery callback' => 'healthstats_json_deliver',
    'type' => MENU_CALLBACK,
  );
  return $items;
}

/**
 * Page callback for api/healthstats.
 *
 * Returns a data array; JSON conversion is handled by the delivery callback.
 *
 * @return array
 *   Associative array with 'users' and 'nodes' counts.
 */
function healthstats_json() {
  $users = db_query('SELECT COUNT(*) FROM {users} WHERE status = :status', array(':status' => 1))->fetchField();
  $nodes = db_query('SELECT COUNT(*) FROM {node} WHERE status = :status', array(':status' => 1))->fetchField();
  return array(
    'users' => (int) $users,
    'nodes' => (int) $nodes,
  );
}

/**
 * Delivery callback for api/healthstats.
 *
 * Access checks produce integer menu status codes (e.g. MENU_ACCESS_DENIED),
 * which drupal_json_output() would wrongly echo as JSON with a 200 status.
 * Route those through the standard HTML delivery so unauthorized requests
 * receive a proper HTTP 403, and encode only real data as JSON.
 *
 * @param mixed $page_callback_result
 *   The result returned by the page callback, or an integer menu status code.
 */
function healthstats_json_deliver($page_callback_result) {
  if (is_int($page_callback_result)) {
    drupal_deliver_html_page($page_callback_result);
  }
  else {
    drupal_json_output($page_callback_result);
  }
}
