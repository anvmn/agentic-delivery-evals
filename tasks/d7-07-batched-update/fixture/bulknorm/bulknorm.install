<?php

/**
 * @file
 * Install/update hooks for Bulk Normalize. Do not modify hook_install().
 *
 * TODO: add hook_update_7100(&$sandbox) per task.md — batched, <=50/invocation.
 */

/**
 * Implements hook_install().
 */
function bulknorm_install() {
  $type = node_type_set_defaults(array(
    'type' => 'item',
    'name' => st('Item'),
    'base' => 'node_content',
    'custom' => TRUE,
  ));
  node_type_save($type);

  if (!field_info_field('field_code')) {
    field_create_field(array(
      'field_name' => 'field_code',
      'type' => 'text',
      'cardinality' => 1,
    ));
  }
  if (!field_info_instance('node', 'field_code', 'item')) {
    field_create_instance(array(
      'field_name' => 'field_code',
      'entity_type' => 'node',
      'bundle' => 'item',
      'label' => 'Code',
    ));
  }
}
