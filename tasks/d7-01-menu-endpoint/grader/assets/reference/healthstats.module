<?php

/**
 * @file
 * Health Stats module — reference solution for grader self-tests.
 */

/**
 * Implements hook_permission().
 */
function healthstats_permission() {
  return array(
    'view healthstats' => array(
      'title' => t('View health statistics'),
      'description' => t('Access the JSON statistics endpoint.'),
    ),
  );
}

/**
 * Implements hook_menu().
 */
function healthstats_menu() {
  $items = array();
  $items['api/healthstats'] = array(
    'title' => 'Health statistics',
    'page callback' => 'healthstats_page',
    'access arguments' => array('view healthstats'),
    'delivery callback' => 'healthstats_deliver',
    'type' => MENU_CALLBACK,
  );
  return $items;
}

/**
 * Delivery callback: JSON for payloads, normal delivery for status codes.
 *
 * Menu status results (MENU_ACCESS_DENIED, MENU_NOT_FOUND) arrive here as
 * integers; handing them to drupal_json_output() would deliver e.g. "3" with
 * HTTP 200. Route them through the standard HTML delivery so access denied
 * is a real 403.
 */
function healthstats_deliver($page_callback_result) {
  if (is_int($page_callback_result)) {
    drupal_deliver_html_page($page_callback_result);
    return;
  }
  drupal_json_output($page_callback_result);
  drupal_page_footer();
}

/**
 * Page callback: assembles the statistics payload.
 */
function healthstats_page() {
  $users = db_query('SELECT COUNT(*) FROM {users} WHERE status = 1 AND uid > 0')->fetchField();
  $nodes = db_query('SELECT COUNT(*) FROM {node} WHERE status = 1')->fetchField();
  return array(
    'users' => (int) $users,
    'nodes' => (int) $nodes,
  );
}
