<?php

/**
 * @file
 * Health Stats module — reference solution for grader self-tests.
 */

/**
 * Implements hook_permission().
 */
function healthstats_permission() {
  return array(
    'view healthstats' => array(
      'title' => t('View health statistics'),
      'description' => t('Access the JSON statistics endpoint.'),
    ),
  );
}

/**
 * Implements hook_menu().
 */
function healthstats_menu() {
  $items = array();
  $items['api/healthstats'] = array(
    'title' => 'Health statistics',
    'page callback' => 'healthstats_page',
    'access arguments' => array('view healthstats'),
    'delivery callback' => 'drupal_json_output',
    'type' => MENU_CALLBACK,
  );
  return $items;
}

/**
 * Page callback: assembles the statistics payload.
 */
function healthstats_page() {
  $users = db_query('SELECT COUNT(*) FROM {users} WHERE status = 1 AND uid > 0')->fetchField();
  $nodes = db_query('SELECT COUNT(*) FROM {node} WHERE status = 1')->fetchField();
  return array(
    'users' => (int) $users,
    'nodes' => (int) $nodes,
  );
}
